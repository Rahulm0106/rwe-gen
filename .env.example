# .env.example — copy to backend/.env and fill in real values.
# NEVER commit a populated .env to git.
#
# Layout mirrors Simon's CLI flag groups in llm/README.md. Each entry shows
# the equivalent CLI flag from llm/cli.py. Commented-out lines use Simon's
# defaults — uncomment only to override.

# ── Common ─────────────────────────────────────────────────────────────────
# --schema-path
SCHEMA_PATH=../docs/protocol_schema_validator.json

# ── LLM (Venice) ───────────────────────────────────────────────────────────
# --venice-api-key
VENICE_API_KEY=your_venice_api_key_here
# --venice-base-url
VENICE_BASE_URL=https://api.venice.ai/api/v1
# --venice-timeout (per-request, seconds)
VENICE_TIMEOUT_SECONDS=60

# --venice-model (repeatable in CLI → CSV here). name[:retries], retries default 2.
# Empty → Simon's defaults [zai-org-glm-5:2, kimi-k2-5:2].
# VENICE_MODELS=zai-org-glm-5:2,kimi-k2-5:2

# --mock-protocol-json (bypass Venice, load local protocol JSON). Leave unset in prod.
# LLM_MOCK_PROTOCOL_PATH=

# --include-venice-system-prompt
# INCLUDE_VENICE_SYSTEM_PROMPT=false

# ── LLM semantic verification (optional second-pass review) ────────────────
# --enable-semantic-verification
LLM_SEMANTIC_VERIFICATION_ENABLED=false

# --llm-verifier-model (repeatable → CSV). Empty → Simon's defaults when
# verification is enabled [kimi-k2-5:2, zai-org-glm-5:1].
# LLM_VERIFIER_MODELS=kimi-k2-5:2,zai-org-glm-5:1

# --llm-verifier-timeout. Unset → falls back to VENICE_TIMEOUT_SECONDS.
# LLM_VERIFIER_TIMEOUT_SECONDS=120

# ── Concept mapping — LOF / IMO ────────────────────────────────────────────
# --concept-mapping-source auto|local|remote
#   auto   = remote IMO first, local CONCEPT.csv fallback (recommended)
#   local  = local deterministic matcher only (no network)
#   remote = remote IMO only, error if credentials missing
CONCEPT_MAPPING_SOURCE=auto

# LOF credentials. Injected into env at startup as client_id / client_secret so
# llm/concept_mapping_module._build_remote_client() picks them up.
LOF_CLIENT_ID=your_lof_client_id
LOF_CLIENT_SECRET=your_lof_client_secret

# --athena-api-base-url (LOF service base URL)
LOF_BASE_URL=https://api.leapoffaith.com/api/service

# LOF path fragments (AthenaApiConfig defaults match — override only if LOF changes).
# LOF_TOKEN_PATH=/generate-access-token/
# IMO_NORMALIZE_PATH=/imo/normalize

# --athena-api-timeout
LOF_TIMEOUT_SECONDS=10

# ── Concept mapping — local ATHENA vocabulary ──────────────────────────────
# CONCEPT.csv is required even in remote mode — IMO returns SNOMED/RxNorm codes
# that are resolved to OMOP concept_ids via local CONCEPT.csv.
# --athena-concept-csv
ATHENA_CONCEPT_CSV_PATH=/data/athena/CONCEPT.csv
# --athena-relationship-csv
ATHENA_CONCEPT_RELATIONSHIP_CSV_PATH=/data/athena/CONCEPT_RELATIONSHIP.csv
# --athena-synonym-csv (optional)
# ATHENA_CONCEPT_SYNONYM_CSV_PATH=/data/athena/CONCEPT_SYNONYM.csv

# --athena-candidate-limit
ATHENA_CANDIDATE_LIMIT=5
# --athena-ambiguity-delta
ATHENA_AMBIGUITY_DELTA=15
# --athena-minimum-match-score
ATHENA_MINIMUM_MATCH_SCORE=120

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://rwe_user:rwe_dev_password@localhost:5432/omop_rwe

# ── Application ────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
