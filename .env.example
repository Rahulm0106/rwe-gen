# .env.example — copy to .env and fill in real values
# NEVER commit .env to git

# ── Venice LLM ────────────────────────────────────────────────────────────────
VENICE_API_KEY=your_venice_api_key_here
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_TIMEOUT_SECONDS=60

# ── LOF / IMO Normalize (concept mapping — primary path) ──────────────────────
# Get these from your Leap of Faith assignment credentials
LOF_CLIENT_ID=your_lof_client_id
LOF_CLIENT_SECRET=your_lof_client_secret
LOF_BASE_URL=https://api.leapoffaith.com/api/service

# concept_mapping_source:
#   auto   = remote IMO first, local CONCEPT.csv fallback (recommended)
#   local  = local only, no network calls
#   remote = remote only, error if credentials missing
CONCEPT_MAPPING_SOURCE=auto

# ── Local ATHENA vocabulary (fallback + code resolution) ──────────────────────
# CONCEPT.csv is required even in remote mode for resolving SNOMED/RxNorm codes.
# Point these to wherever you downloaded the ATHENA vocabulary files.
ATHENA_CONCEPT_CSV_PATH=/data/athena/CONCEPT.csv
ATHENA_CONCEPT_RELATIONSHIP_CSV_PATH=/data/athena/CONCEPT_RELATIONSHIP.csv
# ATHENA_CONCEPT_SYNONYM_CSV_PATH=/data/athena/CONCEPT_SYNONYM.csv  # optional

# ── Protocol schema ────────────────────────────────────────────────────────────
SCHEMA_PATH=../docs/protocol_schema_validator.json

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://rwe_user:rwe_dev_password@localhost:5432/omop_rwe

# ── REMOVED vs Sprint 1 ────────────────────────────────────────────────────────
# GROQ_API_KEY — deleted, replaced by VENICE_API_KEY
